#![enable(implicit_some)]
#![enable(unwrap_newtypes)]
#![enable(unwrap_variant_newtypes)]
// Noctalia rmpc theme - Auto-generated
// Uses M3 colors from active colorscheme
(
    default_album_art_path: None,
    show_song_table_header: true,
    draw_borders: true,
    format_tag_separator: " | ",
    browser_column_widths: [20, 38, 42],
    background_color: "{{colors.surface.default.hex}}",
    text_color: "{{colors.on_surface.default.hex}}",
    header_background_color: None,
    modal_background_color: None,
    modal_backdrop: false,
    preview_label_style: (fg: "{{colors.secondary.default.hex}}"),
    preview_metadata_group_style: (fg: "{{colors.secondary.default.hex}}", modifiers: "Bold"),
    tab_bar: (
        enabled: true,
        active_style: (fg: "{{colors.on_primary.default.hex}}", bg: "{{colors.primary.default.hex}}", modifiers: "Bold"),
        inactive_style: (),
    ),
    highlighted_item_style: (fg: "{{colors.primary.default.hex}}", modifiers: "Bold"),
    current_item_style: (fg: "{{colors.on_primary.default.hex}}", bg: "{{colors.primary.default.hex}}", modifiers: "Bold"),
    borders_style: (fg: "{{colors.surface_variant.default.hex}}"),
    highlight_border_style: (fg: "{{colors.primary.default.hex}}"),
    symbols: (
        song: "󰝚 ",
        dir: " ",
        playlist: "󰲸 ",
        marker: "󰘑  ",
        ellipsis: "...",
        song_style: None,
        dir_style: None,
        playlist_style: None,
    ),
    level_styles: (
        info: (fg: "{{colors.primary.default.hex}}", bg: "{{colors.surface.default.hex}}"),
        warn: (fg: "{{colors.secondary.default.hex}}", bg: "{{colors.surface.default.hex}}"),
        error: (fg: "{{colors.error.default.hex}}", bg: "{{colors.surface.default.hex}}"),
        debug: (fg: "{{colors.tertiary.default.hex}}", bg: "{{colors.surface.default.hex}}"),
        trace: (fg: "{{colors.tertiary.default.hex}}", bg: "{{colors.surface.default.hex}}"),
    ),
    progress_bar: (
        symbols: ["", "█", "◣", "█", "█" ],
        track_style: (fg: "{{colors.surface_variant.default.hex}}"),
        elapsed_style: (fg: "{{colors.primary.default.hex}}"),
        thumb_style: (fg: "{{colors.primary.default.hex}}", bg: "{{colors.surface_variant.default.hex}}"),
    ),
    scrollbar: (
        symbols: ["│", "█", "⊤", "⊥"],
        track_style: (),
        ends_style: (),
        thumb_style: (fg: "{{colors.primary.default.hex}}"),
    ),
    song_table_format: [
        (
            prop: (kind: Property(Title), style: (fg: "{{colors.on_surface.default.hex}}"),
                highlighted_item_style: (fg: "{{colors.on_primary.default.hex}}", modifiers: "Bold"),
                default: (kind: Property(Filename), style: (fg: "{{colors.surface_variant.default.hex}}"),)
            ),
            width: "70%",
        ),
        (
            prop: (kind: Property(Album), style: (fg: "{{colors.surface_variant.default.hex}}"),
                default: (kind: Text("Unknown Album"), style: (fg: "{{colors.surface_variant.default.hex}}"))
            ),
            width: "30%",
        ),
    ],
    components: {},
    layout: Split(
        direction: Vertical,
        panes: [
            (
                size: "4",
                borders: "ALL",
                pane: Pane(Header),
            ),
            (
                size: "3",
                pane: Pane(Tabs),
            ),
            (
                size: "100%",
                borders: "ALL",
                pane: Pane(TabContent),
            ),
            (
                size: "3",
                borders: "ALL",
                pane: Pane(ProgressBar),
            ),
        ],
    ),
    header: (
        rows: [
            (
                left: [
                    (kind: Text("|"), style: (fg: "{{colors.primary.default.hex}}", modifiers: "Bold")),
                    (kind: Property(Status(StateV2(playing_label: "Playing", paused_label: "Paused", stopped_label: "Stopped"))), style: (fg: "{{colors.primary.default.hex}}", modifiers: "Bold")),
                    (kind: Text("|"), style: (fg: "{{colors.primary.default.hex}}", modifiers: "Bold"))
                ],
                center: [
                    (kind: Property(Song(Title)), style: (modifiers: "Bold"),
                        default: (kind: Text("No Song"), style: (modifiers: "Bold"))
                    )
                ],
                right: [
                    (kind: Property(Widget(ScanStatus)), style: (fg: "{{colors.primary.default.hex}}")),
                    (kind: Property(Widget(Volume)), style: (fg: "{{colors.primary.default.hex}}"))
                ]
            ),
            (
                left: [
                    (kind: Property(Status(Elapsed))),
                    (kind: Text(" / ")),
                    (kind: Property(Status(Duration))),
                ],
                center: [
                    (kind: Property(Song(Artist)), style: (fg: "{{colors.secondary.default.hex}}", modifiers: "Bold"),
                        default: (kind: Text("Unknown"), style: (fg: "{{colors.secondary.default.hex}}", modifiers: "Bold"))
                    ),
                    (kind: Text(" - ")),
                    (kind: Property(Song(Album)),
                        default: (kind: Text("Unknown Album"))
                    )
                ],
                right: [
                    (
                        kind: Property(Widget(States(
                            active_style: (fg: "{{colors.primary.default.hex}}", modifiers: "Bold"),
                            separator_style: (fg: "{{colors.surface_variant.default.hex}}")))
                        ),
                        style: (fg: "{{colors.surface_variant.default.hex}}")
                    ),
                ]
            ),
        ],
    ),
    browser_song_format: [
        (
            kind: Group([
                (kind: Property(Track)),
                (kind: Text(" ")),
            ])
        ),
        (
            kind: Group([
                (kind: Property(Artist)),
                (kind: Text(" - ")),
                (kind: Property(Title)),
            ]),
            default: (kind: Property(Filename))
        ),
    ],
    lyrics: (
        timestamp: false
    )
)
